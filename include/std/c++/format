/**
 * formatter specialization for const char*.
 *
 * Outputs the string up to (but not including) the null terminator.
 * Format specifiers are ignored for string output.
 */
template <>
struct formatter<const char*> {
    constexpr const char* parse(format_parse_context& /*ctx*/) {
        return nullptr;
    }

    template <typename FormatContext>
    constexpr typename FormatContext::iterator
        format(const char* val, FormatContext& ctx) const {
        char* out = ctx.out();
        while (*val) {
            *out++ = *val++;
        }
        ctx.advance(out);
        return out;
    }
};

/** formatter specialization for char. */
template <>
struct formatter<char> {
    constexpr const char* parse(format_parse_context& /*ctx*/) {
        return nullptr;
    }

    template <typename FormatContext>
    constexpr typename FormatContext::iterator
        format(char val, FormatContext& ctx) const {
        char* out = ctx.out();
        *out++   = val;
        ctx.advance(out);
        return out;
    }
};

/**
 * formatter specialization for bool.
 *
 * Supports two format types:
 * - 'b' or unspecified: outputs "true"/"false" (boolalpha format).
 * - 'd': outputs "1"/"0" (numeric format).
 *
 * @note This differs from printf-style where %d would output 1/0 for bool.
 *       The C++20 standard specifies 'b' for boolalpha and 'd' for numeric.
 */
template <>
struct formatter<bool> {
    bool M_boolalpha = true;  ///< If true, outputs boolalpha (true/false).

    constexpr const char* parse(format_parse_context& ctx) {
        const char* it = ctx.begin();
        if (it != ctx.end()) {
            if (*it == 'b') {
                M_boolalpha = true;
                ctx.advance_to(it + 1);
            } else if (*it == 'd') {
                M_boolalpha = false;
                ctx.advance_to(it + 1);
            }
        }
        return it;
    }

    template <typename FormatContext>
    constexpr typename FormatContext::iterator
        format(bool val, FormatContext& ctx) const {
        char* out = ctx.out();
        if (M_boolalpha) {
            __format_detail::write_str(out, val ? "true" : "false");
        } else {
            __format_detail::write_str(out, val ? "1" : "0");
        }
        ctx.advance(out);
        return out;
    }
};

/**
 * formatter specialization for int.
 *
 * Supports the following format types:
 * - 'd': decimal (base 10), e.g., 42, -123
 * - 'b': binary (base 2), e.g., 101010
 * - 'o': octal (base 8), e.g., 52
 * - 'x': hexadecimal lowercase (base 16), e.g., 2a
 * - 'X': hexadecimal uppercase (base 16), e.g., 2A
 *
 * @note For negative values, the minus sign is output first, followed by
 *       the absolute value in the specified radix. This matches std::to_chars.
 */
template <>
struct formatter<int> {
    enum class FormatType { Decimal, Binary, Octal, Hex, HexUpper };
    FormatType M_type = FormatType::Decimal;

    constexpr const char* parse(format_parse_context& ctx) {
        const char* it = ctx.begin();
        if (it != ctx.end()) {
            if (*it == 'b') {
                M_type = FormatType::Binary;
                ctx.advance_to(it + 1);
            } else if (*it == 'o') {
                M_type = FormatType::Octal;
                ctx.advance_to(it + 1);
            } else if (*it == 'x') {
                M_type = FormatType::Hex;
                ctx.advance_to(it + 1);
            } else if (*it == 'X') {
                M_type = FormatType::HexUpper;
                ctx.advance_to(it + 1);
            } else if (*it == 'd') {
                M_type = FormatType::Decimal;
                ctx.advance_to(it + 1);
            }
        }
        return it;
    }

    template <typename FormatContext>
    constexpr typename FormatContext::iterator
        format(int val, FormatContext& ctx) const {
        char buf[32];
        char* out = ctx.out();
        unsigned long long uval;

        // Handle negative values: write '-' first, then compute absolute value
        // using the identity: -(val+1)+1 avoids overflow for INT_MIN.
        if (val < 0) {
            *out++ = '-';
            uval = static_cast<unsigned long long>(-(val + 1)) + 1ULL;
        } else {
            uval = static_cast<unsigned long long>(val);
        }

        if (M_type == FormatType::Decimal) {
            ulltoa(uval, buf, 10);
            __format_detail::write_str(out, buf);
            out += strlen(buf);
        } else if (M_type == FormatType::Binary) {
            size_t len = __format_detail::to_bin(buf, uval);
            for (size_t i = 0; i < len; ++i) {
                *out++ = buf[i];
            }
        } else if (M_type == FormatType::Octal) {
            size_t len = __format_detail::to_oct(buf, uval);
            for (size_t i = 0; i < len; ++i) {
                *out++ = buf[i];
            }
        } else {
            bool upper = (M_type == FormatType::HexUpper);
            size_t len = __format_detail::to_hex(buf, uval, upper);
            for (size_t i = 0; i < len; ++i) {
                *out++ = buf[i];
            }
        }
        ctx.advance(out);
        return out;
    }
};

