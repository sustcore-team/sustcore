// Buffer size sufficient for any integer representation:
// - Binary: 64 bits = 64 chars + null = 65 (use 66)
// - Hex: 16 hex digits + null = 17 (sufficient with margin)
// - Decimal: 20 digits for 64-bit + null = 21
constexpr size_t MAXINTBUF = 66;

/**
 * Writes a null-terminated string to the output iterator.
 *
 * @param[out] out  Reference to the output iterator pointer.
 * @param[in]  s    Null-terminated string to write.
 *
 * @note This function does NOT write the null terminator to output.
 */
inline void write_str(char*& out, const char* s) {
    while (*s) {
        *out++ = *s++;
    }
}

/**
 * Converts an unsigned integer to hexadecimal string.
 *
 * @param[out] buf  Output buffer (must be at least MAXINTBUF).
 * @param[in]  val  Value to convert.
 * @param[in]  upper If true, uses uppercase letters (A-F); otherwise lowercase.
 * @return The length of the resulting string (excluding null terminator).
 *
 * @note Handles val == 0 correctly, returning "0".
 */
inline size_t to_hex(char* buf, unsigned long long val, bool upper) {
    if (val == 0) {
        buf[0] = '0';
        buf[1] = '\0';
        return 1;
    }

    static const char digits_l[] = "0123456789abcdef";
    static const char digits_u[] = "0123456789ABCDEF";
    const char* digits           = upper ? digits_u : digits_l;

    char tmp[MAXINTBUF];
    size_t cnt = 0;
    while (val > 0) {
        tmp[cnt++] = digits[val & 0xF];
        val >>= 4;
    }

    // Reverse the digit order (stored LSB-first) into output buffer.
    for (size_t i = 0; i < cnt; ++i) {
        buf[i] = tmp[cnt - 1 - i];
    }
    buf[cnt] = '\0';
    return cnt;
}

/**
 * Converts an unsigned integer to binary string.
 *
 * @param[out] buf  Output buffer (must be at least MAXINTBUF).
 * @param[in]  val  Value to convert.
 * @return The length of the resulting string (excluding null terminator).
 *
 * @note Handles val == 0 correctly, returning "0".
 */
inline size_t to_bin(char* buf, unsigned long long val) {
    if (val == 0) {
        buf[0] = '0';
        buf[1] = '\0';
        return 1;
    }

    char tmp[MAXINTBUF];
    size_t cnt = 0;
    while (val > 0) {
        tmp[cnt++] = '0' + (val & 1ULL);
        val >>= 1;
    }

    // Reverse the digit order (stored LSB-first) into output buffer.
    for (size_t i = 0; i < cnt; ++i) {
        buf[i] = tmp[cnt - 1 - i];
    }
    buf[cnt] = '\0';
    return cnt;
}

/**
 * Converts an unsigned integer to octal string.
 *
 * @param[out] buf  Output buffer (must be at least MAXINTBUF).
 * @param[in]  val  Value to convert.
 * @return The length of the resulting string (excluding null terminator).
 *
 * @note Handles val == 0 correctly, returning "0".
 */
inline size_t to_oct(char* buf, unsigned long long val) {
    if (val == 0) {
        buf[0] = '0';
        buf[1] = '\0';
        return 1;
    }

    char tmp[MAXINTBUF];
    size_t cnt = 0;
    while (val > 0) {
        tmp[cnt++] = '0' + (val & 7ULL);
        val >>= 3;
    }

    // Reverse the digit order (stored LSB-first) into output buffer.
    for (size_t i = 0; i < cnt; ++i) {
        buf[i] = tmp[cnt - 1 - i];
    }
    buf[cnt] = '\0';
    return cnt;
}

/**
 * Converts a floating-point value to fixed-point decimal notation.
 *
 * @param[out] out  Output iterator pointer.
 * @param[in]  val  Value to convert.
 * @return Iterator pointing to the one-past-end of the written characters.
 *
 * Output format: "integer_part.fractional_part" (6 digits after decimal).
 * Handles NaN by outputting "nan" (sign handled by caller).
 * Handles negative values by writing '-' before the absolute value.
 */
inline char* float_to_dec(char* out, double val) {
    if (val != val) {
        write_str(out, "nan");
        return out;
    }

    double absval = val;
    if (val < 0.0) {
        *out++ = '-';
        absval = -val;
    }

    unsigned long long ipart = static_cast<unsigned long long>(absval);
    double fpart              = absval - static_cast<double>(ipart);

    char ibuf[32];
    ulltoa(ipart, ibuf, 10);
    write_str(out, ibuf);

    *out++ = '.';

    for (int i = 0; i < 6; ++i) {
        fpart *= 10.0;
        unsigned long long d = static_cast<unsigned long long>(fpart);
        *out++               = '0' + static_cast<char>(d % 10);
    }

    return out;
}

/**
 * Converts a floating-point value to scientific notation.
 *
 * @param[out] out  Output iterator pointer.
 * @param[in]  val  Value to convert.
 * @param[in]  upper If true, uses 'E' for exponent; otherwise 'e'.
 * @return Iterator pointing to the one-past-end of the written characters.
 *
 * Output format: "digit.fractional_part[DE]sign_exponent" (6 digits after decimal).
 * Example: 1.234560e+02 for 123.456
 * Handles NaN by outputting "nan" (sign handled by caller).
 * Handles zero by outputting "0.000000e+00" (or "0.000000E+00").
 */
inline char* float_to_sci(char* out, double val, bool upper) {
    if (val != val) {
        write_str(out, "nan");
        return out;
    }

    double absval = val;
    if (val < 0.0) {
        *out++ = '-';
        absval = -val;
    }

    if (absval == 0.0) {
        write_str(out, upper ? "0.000000E+00" : "0.000000e+00");
        return out;
    }

    // Normalize to [1.0, 10.0) and track exponent.
    int exp = 0;
    while (absval >= 10.0) {
        absval /= 10.0;
        ++exp;
    }
    while (absval < 1.0) {
        absval *= 10.0;
        --exp;
    }

    unsigned long long ipart = static_cast<unsigned long long>(absval);
    double fpart              = absval - static_cast<double>(ipart);

    char ibuf[8];
    ulltoa(ipart, ibuf, 10);
    write_str(out, ibuf);
    *out++ = '.';

    for (int i = 0; i < 6; ++i) {
        fpart *= 10.0;
        unsigned long long d = static_cast<unsigned long long>(fpart);
        *out++               = '0' + static_cast<char>(d % 10);
    }

    *out++ = upper ? 'E' : 'e';
    if (exp < 0) {
        *out++ = '-';
        exp    = -exp;
    } else {
        *out++ = '+';
    }

    // Zero-pad exponent to 2 digits if needed.
    ulltoa(static_cast<unsigned long long>(exp), ibuf, 10);
    if (exp < 10) {
        *out++ = '0';
    }
    write_str(out, ibuf);

    return out;
}

