/**
 * Creates a format_args object from the provided arguments.
 *
 * @tparam Args  The types of arguments.
 * @param args   The arguments to store.
 * @return A format_args object containing all arguments.
 *
 * @note This function applies __arg_storage transformation to each argument,
 *       handling string literal decay to const char*.
 */
template <typename... Args>
[[nodiscard]]
format_args<__arg_storage_t<remove_reference_t<Args>>...> make_format_args(Args&&... args) {
    return format_args<__arg_storage_t<remove_reference_t<Args>>...>{std::forward<Args>(args)...};
}

// ========================================================================
// vformat declaration
// ========================================================================

/**
 * Formats arguments according to a format string (non-template version).
 *
 * @tparam Args  The types of format arguments.
 * @param fmt   The format string.
 * @param args  The arguments to format.
 * @return A string containing the formatted output.
 */
template <typename... Args>
[[nodiscard]]
string vformat(const char* fmt, const format_args<Args...>& args);

// ========================================================================
// format
// ========================================================================

/**
 * Formats arguments according to a format string.
 *
 * @tparam Args  The types of format arguments.
 * @param fmt   The format string.
 * @param args  The arguments to format.
 * @return A string containing the formatted output.
 *
 * @note Format string syntax:
 *       - Ordinary characters (except { and }) are copied unchanged.
 *       - {{ is replaced with { (escape sequence).
 *       - }} is replaced with } (escape sequence).
 *       - {I} or {I:format} is a replacement field for argument I (0-indexed).
 *       - {} is auto-indexed, incrementing from 0.
 *
 * @example
 *   std::format("Hello {}!", "world")  // "Hello world!"
 *   std::format("{1} {0}", "first", "second")  // "second first"
 *   std::format("{{hello}}")  // "{hello}"
 */
template <typename... Args>
[[nodiscard]]
string format(const char* fmt, Args&&... args) {
    return vformat(fmt, make_format_args(args...));
}

// ========================================================================
// format_to
// ========================================================================

/**
 * Formats arguments directly into an output range.
 *
 * @tparam OutputIt  Output iterator type.
 * @tparam Args       The types of format arguments.
 * @param it          Output iterator to write to.
 * @param fmt         The format string.
 * @param args        The arguments to format.
 * @return Iterator pointing to the position after the last character written.
 *
 * @note This function first formats into a temporary string, then copies
 *       to the output range. For better performance with OutputIt ranges,
 *       consider using the vformat overload directly.
 */
template <typename OutputIt, typename... Args>
OutputIt format_to(OutputIt it, const char* fmt, Args&&... args) {
    string result = vformat(fmt, make_format_args(args...));
    for (char c : result) {
        *it++ = c;
    }
    return it;
}

