/**
 * formatter specialization for float.
 *
 * Supports the following format types:
 * - 'f' or 'F': fixed-point notation, e.g., 3.140000
 * - 'e' or 'E': scientific notation, e.g., 3.140000e+00
 * - 'g' or 'G': general notation (uses shortest representation)
 * - unspecified: defaults to general notation
 */
template <>
struct formatter<float> {
    enum class FormatType { General, Fixed, Exp, ExpUpper };
    FormatType M_type = FormatType::General;

    constexpr const char* parse(format_parse_context& ctx) {
        const char* it = ctx.begin();
        if (it != ctx.end()) {
            if (*it == 'f' || *it == 'F') {
                M_type = FormatType::Fixed;
                ctx.advance_to(it + 1);
            } else if (*it == 'e') {
                M_type = FormatType::Exp;
                ctx.advance_to(it + 1);
            } else if (*it == 'E') {
                M_type = FormatType::ExpUpper;
                ctx.advance_to(it + 1);
            } else if (*it == 'g' || *it == 'G') {
                M_type = FormatType::General;
                ctx.advance_to(it + 1);
            }
        }
        return it;
    }

    template <typename FormatContext>
    constexpr typename FormatContext::iterator
        format(float val, FormatContext& ctx) const {
        char* out = ctx.out();
        if (M_type == FormatType::Exp) {
            out = __format_detail::float_to_sci(out, static_cast<double>(val), false);
        } else if (M_type == FormatType::ExpUpper) {
            out = __format_detail::float_to_sci(out, static_cast<double>(val), true);
        } else {
            out = __format_detail::float_to_dec(out, static_cast<double>(val));
        }
        ctx.advance(out);
        return out;
    }
};

