// format_parse_context
// ========================================================================

/**
 * Context object for parsing a format specification string.
 *
 * @note This class is based on std::format_parse_context from C++20.
 * It tracks the current position within the format string and provides
 * iteration capabilities for the formatter's parse() method.
 *
 * @example
 *   format_parse_context ctx("{d}", 3);
 *   // ctx.begin() points to 'd', ctx.end() points past '}';
 */
class format_parse_context {
public:
    using iterator = const char*;  ///< Iterator type for traversing the format string.

    /** Constructs a parse context pointing to [fmt, fmt + len). */
    constexpr format_parse_context(const char* fmt, size_t len) noexcept
        : M_fmt(fmt), M_len(len), M_pos(0) {}

    /** Returns an iterator to the beginning of the format string. */
    constexpr iterator begin() const noexcept {
        return M_fmt + M_pos;
    }

    /** Returns an iterator to the end of the format string. */
    constexpr iterator end() const noexcept {
        return M_fmt + M_len;
    }

    /** Returns the length of the format string. */
    constexpr size_t size() const noexcept {
        return M_len;
    }

    /**
     * Advances the parse context to the given iterator position.
     *
     * @param it  Iterator to advance to. Must be within [begin(), end()].
     *           If it exceeds end(), position is clamped to end().
     */
    constexpr void advance_to(iterator it) noexcept {
        if (it >= M_fmt && it <= M_fmt + M_len) {
            M_pos = static_cast<size_t>(it - M_fmt);
        } else if (it > M_fmt + M_len) {
            M_pos = M_len;
        }
    }

private:
    const char* M_fmt;   ///< Pointer to the start of the format string.
    size_t M_len;        ///< Length of the format string.
    size_t M_pos;        ///< Current parsing position (index into M_fmt).
};

// ========================================================================
// format_context
// ========================================================================

/**
 * Context object for formatting output.
 *
 * @note This class is based on std::format_context from C++20.
 * It provides the output iterator and manages cursor position during
 * formatting operations.
 */
class format_context {
public:
    using char_type = char;  ///< Character type for output.
    using iterator = char*;  ///< Output iterator type.

    /** Constructs a format context with the given output iterator. */
    explicit format_context(iterator out) : M_out(out) {}

    /** Returns the current output iterator position. */
    iterator out() {
        return M_out;
    }

    /**
     * Advances the output iterator to a new position.
     *
     * @param it  New position for the output iterator.
     */
    void advance(iterator it) {
        M_out = it;
    }

private:
    iterator M_out;  ///< Current output position.
};

