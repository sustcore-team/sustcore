    constexpr const char* parse(format_parse_context& ctx) {
        const char* it = ctx.begin();
        if (it != ctx.end()) {
            if (*it == 'b') {
                M_type = FormatType::Binary;
                ctx.advance_to(it + 1);
            } else if (*it == 'o') {
                M_type = FormatType::Octal;
                ctx.advance_to(it + 1);
            } else if (*it == 'x') {
                M_type = FormatType::Hex;
                ctx.advance_to(it + 1);
            } else if (*it == 'X') {
                M_type = FormatType::HexUpper;
                ctx.advance_to(it + 1);
            } else if (*it == 'd') {
                M_type = FormatType::Decimal;
                ctx.advance_to(it + 1);
            }
        }
        return it;
    }

    template <typename FormatContext>
    constexpr typename FormatContext::iterator
        format(unsigned long long val, FormatContext& ctx) const {
        char buf[32];
        char* out = ctx.out();
        if (M_type == FormatType::Decimal) {
            ulltoa(val, buf, 10);
            __format_detail::write_str(out, buf);
            out += strlen(buf);
        } else if (M_type == FormatType::Binary) {
            size_t len = __format_detail::to_bin(buf, val);
            for (size_t i = 0; i < len; ++i) {
                *out++ = buf[i];
            }
        } else if (M_type == FormatType::Octal) {
            size_t len = __format_detail::to_oct(buf, val);
            for (size_t i = 0; i < len; ++i) {
                *out++ = buf[i];
            }
        } else {
            bool upper = (M_type == FormatType::HexUpper);
            size_t len = __format_detail::to_hex(buf, val, upper);
            for (size_t i = 0; i < len; ++i) {
                *out++ = buf[i];
            }
        }
        ctx.advance(out);
        return out;
    }
};

/**
 * formatter specialization for const void*.
 *
 * Outputs the pointer address in hexadecimal with "0x" prefix.
 * Format specifiers are ignored for pointer output.
 */
template <>
struct formatter<const void*> {
    constexpr const char* parse(format_parse_context& /*ctx*/) {
        return nullptr;
