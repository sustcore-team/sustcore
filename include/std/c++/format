namespace __format_detail {

/**
 * Implementation helper for formatting a specific argument by index.
 *
 * @tparam I      The total number of elements in this node.
 * @tparam Head   The type of the first argument.
 * @tparam Tail   The types of remaining arguments.
 * @param out     Output buffer pointer.
 * @param idx     Index of the argument to format.
 * @param args    The format_args object.
 * @param spec    Format specification string.
 * @param spec_len Length of the format specification.
 * @return Iterator pointing past the last character written.
 *
 * @note For idx == 0, formats Head directly. Otherwise, casts to the
 *       base class (which drops Head) and recurses with idx-1.
 */
template <size_t I, typename Head, typename... Tail>
char* format_arg_by_idx_impl(char* out, size_t idx,
                              const format_args<Head, Tail...>& args,
                              const char* spec, size_t spec_len) {
    if (idx == 0) {
        auto& val = args.template get<0>();
        using T  = __arg_storage_t<decay_t<decltype(val)>>;
        formatter<T> f;
        format_parse_context pctx(spec, spec_len);
        f.parse(pctx);
        format_context fctx(out);
        return f.format(val, fctx);
    } else if constexpr (I == 1) {
        // Only 2 elements: recurse to 2-element overload via base class.
        return format_arg_by_idx_impl<I - 1>(out, idx - 1,
            *static_cast<const format_args<Tail...>*>(&args), spec, spec_len);
    } else if constexpr (I > 1) {
        // Recurse to next level via base class (drops Head).
        return format_arg_by_idx_impl<I - 1>(out, idx - 1,
            *static_cast<const format_args<Tail...>*>(&args), spec, spec_len);
    } else {
        return out;  // out of range
    }
}

/** Base case for single-element format_args. */
template <typename Head>
char* format_arg_by_idx_impl(char* out, size_t idx,
                              const format_args<Head>& args,
                              const char* spec, size_t spec_len) {
    if (idx == 0) {
        auto& val = args.template get<0>();
        using T  = __arg_storage_t<decay_t<decltype(val)>>;
        formatter<T> f;
        format_parse_context pctx(spec, spec_len);
        f.parse(pctx);
        format_context fctx(out);
        return f.format(val, fctx);
    }
    return out;  // out of range
}

/**
 * Overload for 2-element format_args.
 *
 * @note This separate overload is needed because the base class (format_args<Tail>)
 *       has only 1 element, so the recursive cast approach doesn't work for 2 elements.
 */
template <typename Head, typename Tail>
char* format_arg_by_idx_impl(char* out, size_t idx,
                              const format_args<Head, Tail>& args,
                              const char* spec, size_t spec_len) {
    if (idx == 0) {
        auto& val = args.template get<0>();
        using T  = __arg_storage_t<decay_t<decltype(val)>>;
        formatter<T> f;
        format_parse_context pctx(spec, spec_len);
        f.parse(pctx);
        format_context fctx(out);
        return f.format(val, fctx);
    } else {
        // idx == 1, get from base class (format_args<Tail>).
        auto& val = args.template get<1>();
        using T  = __arg_storage_t<decay_t<decltype(val)>>;
        formatter<T> f;
        format_parse_context pctx(spec, spec_len);
        f.parse(pctx);
        format_context fctx(out);
        return f.format(val, fctx);
    }
}

/**
 * Top-level dispatcher for argument formatting.
 *
 * @tparam Args  The types of all format arguments.
 * @param out    Output buffer pointer.
 * @param idx    Index of the argument to format.
 * @param args   The format_args object.
 * @param spec   Format specification string.
 * @param spec_len Length of the format specification.
 * @return Iterator pointing past the last character written.
 */
template <typename... Args>
char* format_arg_by_idx(char* out, size_t idx,
                        const format_args<Args...>& args,
                        const char* spec, size_t spec_len) {
    if constexpr (sizeof...(Args) == 0) {
        return out;
    } else {
        return format_arg_by_idx_impl<sizeof...(Args) - 1>(out, idx, args, spec, spec_len);
    }
}

}  // namespace __format_detail

// ========================================================================
// vformat implementation
// ========================================================================

/**
 * Formats arguments according to a format string.
 *
 * @tparam Args  The types of format arguments.
 * @param fmt   The format string.
 * @param args  The arguments to format.
 * @return A string containing the formatted output.
 *
 * @note The format string is parsed left-to-right. Characters other than
 *       '{' and '}' are copied to the output. When '{' is encountered,
 *       it may be followed by an optional argument index, a ':' for format
 *       specifiers, and must be closed by '}'. The sequence '{{' produces
 *       a literal '{' and '}}' produces a literal '}'.
 *
 * Escape sequences:
 *   {{  -> {
 *   }}  -> }
 *
 * Replacement field syntax:
 *   { [argument-index] [ : format-spec ] }
 *
 * @example
 *   vformat("Hello {}!", make_format_args("world"))
 *   // Returns "Hello world!"
 */
template <typename... Args>
[[nodiscard]]
string vformat(const char* fmt, const format_args<Args...>& args) {
    string result;
    result.reserve(64);

    const char* p = fmt;
    unsigned next_arg_idx = 0;

    while (*p) {
        if (*p == '{') {
            const char* brace_start = p;
            p++;

            // Handle escaped '{' -> output literal '{'.
            if (*p == '{') {
                result.push_back('{');
                p++;
                continue;
            }

            // Parse argument index (0-based).
            unsigned idx = 0;
            bool has_idx = false;
            if (*p >= '0' && *p <= '9') {
                has_idx = true;
                while (*p >= '0' && *p <= '9') {
                    idx = idx * 10 + static_cast<unsigned>(*p - '0');
                    p++;
                }
            }

            // Parse format specification after ':'.
            const char* spec = "";
            size_t spec_len = 0;
            if (*p == ':') {
                const char* spec_start = p + 1;
                int depth = 1;
                // Skip nested braces in format spec (e.g., {:{}}).
                while (*p && depth > 0) {
                    if (*p == '{')
                        depth++;
                    else if (*p == '}')
                        depth--;
                    if (depth > 0)
                        p++;
                }
                spec = spec_start;
                spec_len = static_cast<size_t>(p - spec_start);
            }

            // Find closing '}' for the replacement field.
            while (*p && *p != '}') {
                p++;
            }
            if (*p != '}') {
                // Unmatched '{' - output as-is.
                result.append(brace_start,
                              static_cast<size_t>(p - brace_start));
                break;
            }
            p++;

            // Assign argument index: auto-increment or use explicit value.
            if (!has_idx) {
                idx = next_arg_idx++;
            } else {
                next_arg_idx = idx + 1;
            }

            // Bounds check.
            if (idx >= sizeof...(Args)) {
                result.push_back('?');
                continue;
            }

            // Format the argument into a temporary buffer, then append.
            char buf[256] = {};
            __format_detail::format_arg_by_idx(buf, idx, args, spec, spec_len);
            result.append(buf, strlen(buf));
        } else if (*p == '}') {
            // Handle escaped '}' -> output literal '}'.
            if (p[1] == '}') {
                result.push_back('}');
                p += 2;
            } else {
                // Standalone '}' - output as-is (non-standard but permissive).
                result.push_back('}');
                p++;
            }
        } else {
            result.push_back(*p);
            p++;
        }
    }

    return result;
}

}  // namespace std
