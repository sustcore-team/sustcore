    template <typename FormatContext>
    constexpr typename FormatContext::iterator
        format(const void* val, FormatContext& ctx) const {
        char* out = ctx.out();
        __format_detail::write_str(out, "0x");

        unsigned long long addr = reinterpret_cast<unsigned long long>(val);
        char buf[__format_detail::MAXINTBUF];
        size_t len = __format_detail::to_hex(buf, addr, false);
        for (size_t i = 0; i < len; ++i) {
            *out++ = buf[i];
