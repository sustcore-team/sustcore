// ========================================================================
// __arg_storage
//
// Type transformation trait for format argument storage.
// Handles the special case of string literals (char arrays) which decay
// to const char* pointers, while other types use their decayed form.
// ========================================================================

/**
 * Type transformation trait for format argument storage.
 *
 * For most types, the stored type is decay_t<T> (reference removed, array
 * decayed to pointer). For char arrays (string literals), the stored type
 * is explicitly const char* to preserve the string content.
 *
 * @tparam T  The type to transform.
 *
 * @example
 *   int -> int
 *   int& -> int
 *   char[6] -> const char*
 *   const char[6] -> const char*
 */
template <typename T>
struct __arg_storage {
    using type = decay_t<T>;
};

/** Specialization: char arrays decay to const char* for string literals. */
template <size_t N>
struct __arg_storage<char[N]> {
    using type = const char*;
};

/** Specialization: const char arrays also decay to const char*. */
template <size_t N>
struct __arg_storage<const char[N]> {
    using type = const char*;
};

/** Convenience alias for the transformed type. */
template <typename T>
using __arg_storage_t = typename __arg_storage<T>::type;

// ========================================================================
// format_args
//
// A type-safe container for format arguments, using a singly-linked list
// inheritance chain. Each node stores one argument and chains to the next.
// get<I>() recursively descends through the chain to retrieve element I.
// ========================================================================

/**
 * Type-safe container for format arguments.
 *
 * @tparam Args  The types of arguments stored in this container.
 *
 * @note Uses private inheritance to create a singly-linked chain of nodes.
 * Each node stores one argument in M_head and inherits from a node
 * containing the remaining arguments. This avoids dynamic allocation.
 *
 * @example
 *   format_args<int, const char*, double> args(42, "hello", 3.14);
 *   args.get<0>();  // returns 42
 *   args.get<1>();  // returns "hello"
 *   args.get<2>();  // returns 3.14
 */
template <typename... Args>
class format_args;

// Empty specialization: terminal case with no arguments.
template <>
class format_args<> {
public:
    format_args() = default;
    static constexpr size_t size() { return 0; }

    /** Returns nullptr for out-of-range index. */
    template <size_t> const void* get() const { return nullptr; }
};

/**
 * Recursive specialization: stores first argument in M_head,
 * chains to base class for remaining arguments.
 */
template <typename Head, typename... Tail>
class format_args<Head, Tail...> : public format_args<Tail...> {
private:
    using base = format_args<Tail...>;
    __arg_storage_t<Head> M_head;  ///< Stored argument (array decayed if needed).

public:
    /**
     * Constructor forwarding arguments to appropriate storage.
     *
     * @param head  First argument (may be decayed to pointer for arrays).
     * @param tail  Remaining arguments.
     */
    template <typename H, typename... Ts>
    format_args(H&& head, Ts&&... tail)
        : base(std::forward<Ts>(tail)...),
          M_head(__arg_storage_t<Head>(std::forward<H>(head))) {}

    static constexpr size_t size() { return 1 + sizeof...(Tail); }

    /**
     * Gets a reference to the I-th argument.
     *
     * @tparam I  Index of the argument to retrieve.
     * @return Reference to the stored argument.
     *
     * @note For I == 0, returns M_head. Otherwise recursively calls
     *       base::get<I-1>() to descend the chain.
     */
    template <size_t I>
    constexpr auto& get() {
        if constexpr (I == 0) {
            return M_head;
        } else {
            return base::template get<I - 1>();
        }
    }

    /// Const overload of get().
    template <size_t I>
    constexpr const auto& get() const {
        if constexpr (I == 0) {
            return M_head;
        } else {
            return base::template get<I - 1>();
        }
    }
};

