#pragma once

#include <cstddef>
#include <limits>
#include <new>
#include <type_traits>

namespace std {
    template <class T>
    constexpr T* to_address(T* p) noexcept {
        return p;
    }

    template <class T>
    constexpr T* to_address(T& p) noexcept {
        return &p;
    }

    template <typename T>
    class allocator {
    public:
        // 必要类型别名
        using value_type      = T;
        using pointer         = T*;
        using const_pointer   = const T*;
        using reference       = T&;
        using const_reference = const T&;
        using size_type       = size_t;
        using difference_type = ptrdiff_t;
        using is_always_equal = true_type;  // 无状态分配器总是相等

        // 默认构造函数、复制构造函数、析构函数（无状态，可默认）
        allocator() = default;
        template <typename U>
        allocator(const allocator<U>&) noexcept {}  // 支持跨类型转换

        // 分配 n 个 T 对象的内存
        pointer allocate(size_type n, const void* hint = nullptr) {
            if (n == 0)
                return nullptr;  // 标准允许分配 0 字节时返回空指针
            // 检查是否超出最大可分配大小
            if (n > numeric_limits<size_type>::max() / sizeof(T))
                _THROW(bad_alloc());  // 超出限制，抛出 bad_alloc

            // 调用全局 operator new，失败时它会抛出 bad_alloc
            void* ptr = ::operator new(n * sizeof(T));
            return static_cast<pointer>(ptr);
        }

        // 释放内存
        void deallocate(pointer p, size_type n) noexcept {
            // 调用全局 operator delete，它对空指针安全
            ::operator delete(p);
        }

        // C++11/14 中需要 construct/destroy（C++17
        // 后容器不再强制使用它们，但保留无害）
        template <typename U, typename... Args>
        void construct(U* p, Args&&... args) {
            ::new ((void*)p) U(forward<Args>(args)...);
        }

        template <typename U>
        void destroy(U* p) noexcept {
            p->~U();
        }

        // rebind 机制，允许分配器为其他类型分配内存
        template <typename U>
        struct rebind {
            using other = allocator<U>;
        };
    };

    // 无状态分配器总是相等
    template <typename T, typename U>
    bool operator==(const allocator<T>&, const allocator<U>&) noexcept {
        return true;
    }
    template <typename T, typename U>
    bool operator!=(const allocator<T>&, const allocator<U>&) noexcept {
        return false;
    }

    namespace __op {
        template <typename _Tp>
        using ptr = typename _Tp::pointer;
        template <typename _Tp>
        using c_ptr = typename _Tp::const_pointer;
        template <typename _Tp>
        using v_ptr = typename _Tp::void_pointer;
        template <typename _Tp>
        using cv_ptr = typename _Tp::const_void_pointer;
        template <typename _Tp>
        using pocca = typename _Tp::propagate_on_container_copy_assignment;
        template <typename _Tp>
        using pocma = typename _Tp::propagate_on_container_move_assignment;
        template <typename _Tp>
        using pocs = typename _Tp::propagate_on_container_swap;
        template <typename _Tp>
        using equal = type_identity_t<typename _Tp::is_always_equal>;
        template <typename _Tp>
        using diff_t = typename _Tp::difference_type;
        template <typename _Tp>
        using size_type = typename _Tp::size_type;
    };  // namespace __op

    template <class Ptr>
    struct pointer_traits {
        using pointer         = Ptr;
        // todo: 实际上element_type应当为 Ptr::element_type
        // 或在Ptr为特化SomeTemplate<T, ...>时为T
        // 但我们目前先考虑第一种情况, 后续再完善
        using element_type    = Ptr::element_type;
        using difference_type = __detected_or_t<ptrdiff_t, __op::diff_t, Ptr>;

        // todo: 实际上element_type应当为 Ptr::rebind<T>
        // 或在Ptr为特化SomeTemplate<T, ...>时为SomeTemplate<U, ...>
        // 但我们目前先考虑第一种情况, 后续再完善
        template <typename Up>
        using rebind = Ptr::template rebind<Up>;
    };

    template <class T>
    struct pointer_traits<T*> {
        using pointer         = T*;
        using element_type    = T;
        using difference_type = ptrdiff_t;
        template <typename Up>
        using rebind = Up*;
    };

    template <class Alloc>
    struct allocator_traits {
    public:
        using allocator_type = Alloc;
        using value_type     = allocator_type::value_type;
        using pointer = __detected_or_t<value_type*, __op::ptr, allocator_type>;
        using const_pointer =
            __detected_or_t<const value_type*, __op::c_ptr, allocator_type>;
        using void_pointer =
            __detected_or_t<void*, __op::v_ptr, allocator_type>;
        using const_void_pointer =
            __detected_or_t<const void*, __op::cv_ptr, allocator_type>;
        using difference_type =
            __detected_or_t<std::ptrdiff_t, __op::diff_t, allocator_type>;
        using size_type = __detected_or_t<std::make_unsigned_t<difference_type>,
                                          __op::size_type, allocator_type>;
        using propagate_on_container_copy_assignment =
            __detected_or_t<false_type, __op::pocca, allocator_type>;
        using propagate_on_container_move_assignment =
            __detected_or_t<false_type, __op::pocma, allocator_type>;
        using propagate_on_container_swap =
            __detected_or_t<false_type, __op::pocs, allocator_type>;
        using is_always_equal =
            __detected_or_t<false_type, __op::equal, allocator_type>;

        // 注: 当Alloc::rebind<_Up>::other不存在时
        // 若Alloc形如SomeTemplate<T, ...>, 则我们尝试使用SomeTemplate<Up, ...>
        template <class _Up>
        using rebind_alloc = Alloc::template rebind<_Up>::other;

        template <class _Up>
        using rebind_traits = allocator_traits<rebind_alloc<_Up>>;

        static pointer allocate(allocator_type& a, size_type n) {
            return a.allocate(n);
        }

        static void deallocate(allocator_type& a, pointer p, size_type n) {
            a.deallocate(p, n);
        }

        template <typename... Args>
        static void construct(allocator_type& a, pointer p, Args&&... args) {
            a.construct(p, forward<Args>(args)...);
        }

        void destroy(allocator_type& a, pointer p) noexcept {
            a.destroy(p);
        }
    };

}  // namespace std