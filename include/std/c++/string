        template <class InputIt>
        constexpr basic_string &__replace(size_type pos, size_type count,
                                          InputIt first, InputIt last) {
            if (pos > size()) {
                _THROW(out_of_range("basic_string::replace: pos out of range"));
            }
            const size_type s_count      = std::distance(first, last);
            const size_type erase_count  = std::min(count, size() - pos);
            const size_type insert_count = std::min(s_count, erase_count);
            const size_type new_size     = size() - erase_count + insert_count;
            U_prepare_capacity(new_size);
            // 我们有:
            // insert_count <= s_count, erase_count <= count, size() - pos
            // [pos, pos + insert_count) 替换为 s 的前 insert_count 个字符
            // 而[pos + erase_count, size()] 的内容向前移动 [pos + insert_count,
            // ...]

            if (erase_count > insert_count) {
                // 移动的
                const size_type move_count = size() - pos - erase_count + 1;
                Traits::move(data() + pos + insert_count,
                             data() + pos + erase_count, move_count);
            }

            for (size_type i = 0; i < insert_count; ++i) {
                U_assign(pos + i, *(first + i));
            }
            return *this;
        }

