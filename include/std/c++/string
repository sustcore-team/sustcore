        // erase
        constexpr basic_string &erase(size_type index = 0,
                                      size_type count = npos) {
            if (index > size()) {
                _THROW(out_of_range("basic_string::erase: index out of range"));
            }
            if (count == 0) {
                return *this;
            }
            count = std::min(count, size() - index);
            // 将 [index + count, size()) 的内容向前移动 count 个位置
            Traits::move(data() + index, data() + index + count,
                         size() - index - count + 1);
            D_size -= count;
            return *this;
        }

        constexpr iterator erase(const_iterator pos) {
            size_type index = pos - begin();
            erase(index, 1);
            return begin() + index;
        }

        constexpr iterator erase(const_iterator first, const_iterator last) {
            size_type index = first - begin();
            size_type count = last - first;
            erase(index, count);
            return begin() + index;
        }

