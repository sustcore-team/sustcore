#pragma once

#include <exception>
#include <bits/cow_string.h>
#include <cstring>

namespace std {
    class logic_error : public exception {
        __cow_string _msg;
    public:
        // NOLINTNEXTLINE(modernize-pass-by-value)
        explicit logic_error(const string &what_arg)
            : exception(), _msg(what_arg) {}
        explicit logic_error(const char *what_arg)
            : exception(), _msg(what_arg, strlen(what_arg)) {}
        // NOLINTNEXTLINE(modernize-pass-by-value)
        logic_error(const logic_error &other)            = default;
        logic_error &operator=(const logic_error &other) = default;
        logic_error(logic_error &&)                      = default;
        logic_error &operator=(logic_error &&)           = default;
        virtual ~logic_error() override                  = default;
        [[nodiscard]]
        const char *what() const noexcept override {
            return _msg.c_str();
        }
#ifdef __SUS_NO_RTTI__
        [[nodiscard]]
        const char* type() const override {
            return "std::logic_error";
        }
#endif
    };

